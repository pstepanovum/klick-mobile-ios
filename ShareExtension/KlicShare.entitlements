<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Same app group as the main app: grants this extension the shared keychain access
         group holding the auth tokens (TokenStore). -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.klic.mobile.app</string>
    </array>
</dict>
</plist>
